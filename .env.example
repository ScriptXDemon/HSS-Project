# Root env file is only for local monorepo development.
# For deployment, use apps/web/.env.example and apps/api/.env.example.

DEFAULT_DB_ENGINE=mongo
MONGODB_URI=mongodb://127.0.0.1:27017/hss_db
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
ENCRYPTION_KEY=
ADMIN_BOOTSTRAP_TOKEN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BACKEND_INTERNAL_URL=http://localhost:3001/api
NEXT_PUBLIC_API_BASE=/api
UPLOAD_PUBLIC_URL_BASE=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_R2_REGION=auto
DISABLE_LOCAL_UPLOAD_FALLBACK=false
NEXT_PUBLIC_DONATION_QR_IMAGE_URL=/donation-qr.jpeg
NEXT_PUBLIC_DONATION_QR_TITLE=Hindu Suraksha Sangh Donation QR
NEXT_PUBLIC_DONATION_QR_NOTE=Scan the QR, pay, and upload the payment screenshot for manual verification.