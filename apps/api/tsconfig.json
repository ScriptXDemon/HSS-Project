{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@hss/domain": ["../../packages/domain/src/index.ts"],
      "@hss/domain/*": ["../../packages/domain/src/*"]
